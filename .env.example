AI_PROVIDER=academiccloud
ACADEMIC_CLOUD_API_KEY=your_academic_cloud_key_here
ACADEMIC_CLOUD_BASE_URL=https://chat-ai.academiccloud.de/v1
ACADEMIC_CLOUD_MODEL=llama-3.3-70b-instruct

# Optional Gemini fallback. Leave empty unless you want to use Gemini instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Frontend-only public API base. This is safe to expose because it is just a URL.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8765
